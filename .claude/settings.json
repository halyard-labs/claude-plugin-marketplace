{
  "plugins": [
    {
      "path": "./plugins/halyard"
    }
  ],
  "enabledPlugins": {
    "halyard@halyard-labs": true
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "Bash(chmod +x *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "Bash(git check-ignore *)",
      "Bash(git checkout *)"
    ]
  }
}
